# Anthropic API (required for PDF extraction)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...

# NextAuth (required)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://azure-quote-builder.vercel.app

# Vercel Postgres (required for user accounts)
POSTGRES_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=...
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...

# Email - Resend (recommended)
RESEND_API_KEY=re_...

# Email - SMTP fallback (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password

# Signup invite code (optional, default: AZURE2026)
NEXT_PUBLIC_INVITE_CODE=AZURE2026
